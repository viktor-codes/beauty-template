# Copy to `.env.local` and fill in values before running locally.
# Never commit `.env.local` — it is gitignored.

# -----------------------------------------------------------------------------
# Site (required in production on Vercel)
# -----------------------------------------------------------------------------

# Canonical public URL, no trailing slash. Used for metadata, JSON-LD, sitemap, Stripe redirects.
# Example: https://The Skinbar.example.com
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 measurement ID. Leave empty to disable analytics loading.
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Sanity CMS
# -----------------------------------------------------------------------------

# Public project identifier from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity Studio (sanity/.env — same project/dataset as above)
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production

# Dataset name (typically "production" or "development")
NEXT_PUBLIC_SANITY_DATASET=production

# GROQ API version date. Bump only when upgrading Sanity client behaviour.
NEXT_PUBLIC_SANITY_API_VERSION=2025-05-05

# Server GROQ reads use api.sanity.io (useCdn: false in lib/sanity/client.ts) for fast post-webhook updates.

# Server-only read token for draft preview or private datasets. Do not expose to the client.
# Create at: sanity.io/manage → Project → API → Tokens (Viewer or custom read role)
SANITY_API_READ_TOKEN=

# Server-only token with Editor role — for seed scripts and gift voucher orders (webhook).
# Never expose to the client.
SANITY_API_WRITE_TOKEN=

# Shared secret for on-demand revalidation (Sanity webhook → POST /api/revalidate).
# Generate a long random string. In sanity.io/manage → API → Webhooks, set header:
# Authorization: Bearer <same value>
SANITY_REVALIDATE_SECRET=

# -----------------------------------------------------------------------------
# Stripe (gift voucher checkout)
# -----------------------------------------------------------------------------

# Publishable key (safe for client-side Stripe.js if needed later)
# Example: pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret key — server-only. Used for Checkout Sessions and webhook verification context.
# Example: sk_test_...
STRIPE_SECRET_KEY=

# Signing secret from Stripe Dashboard → Developers → Webhooks
# Local dev: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Resend (contact form — optional until Phase 6)
# -----------------------------------------------------------------------------

# API key from resend.com/api-keys
RESEND_API_KEY=

# Verified sender domain in Resend (must match your domain DNS records)
# Example: The Skinbar <hello@yourdomain.com>
RESEND_FROM_EMAIL=

# Inbox that receives contact form submissions
RESEND_TO_EMAIL=
